# Copy this file to `.env`, `.env.local`, or `.env.$NODE_ENV`
# Examples: `.env.development`, `.env.production`, `.env.test`

# Optional: enables AI-backed metric retention advice.
OPENAI_API_KEY=

# Optional: overrides the default OpenAI model.
OPENAI_MODEL=gpt-5.4

# Local data and network settings.
DATA_DIR=data
HOST=127.0.0.1
HTTP_PORT=14318
OTLP_GRPC_PORT=14317
PROTO_DIR=packages/proto
