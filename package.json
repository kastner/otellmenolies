{
  "name": "otellmenolies",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:ingest": "bun --filter @otellmenolies/ingest run dev",
    "dev:dashboard": "bun --filter @otellmenolies/dashboard run dev",
    "test": "turbo run test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "turbo": "^2.5.6",
    "typescript": "^5.8.2"
  }
}
